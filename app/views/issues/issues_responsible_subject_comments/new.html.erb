<%= turbo_frame_tag "activity_form_content" do %>
  <div class="add-comment-form-con" data-controller="autofocus delegate" data-autofocus-target="scrollAnchor" data-delegate-target="selectorRoot">
    <div class="add-comment-form">
      <div class="title">
        <% if @resolves %>
          Označiť za vyriešený
        <% else %>
          Pridať komentár
        <% end %>
      </div>
      <div class="description">
        <% if @resolves %>
          Po označení podnetu za vyriešený sa uzavrie diskusia.
        <% else %>
          Po pridaní prvého komentára sa automaticky zmení stav podnetu.
        <% end %>
      </div>
      <%= render "form", issue: @issue, comment: @comment %>
    </div>
  </div>
<% end %>
