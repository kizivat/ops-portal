<div class="mx-auto md:w-2/3 w-full flex">
  <div class="mx-auto">
    <% if notice.present? %>
      <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
    <% end %>

    <div class="mb-5 bg-green-50 p-5 rounded-lg">
      <% @issue.activities.each do |activity| %>
        <div class="my-5">
          <strong class="block font-medium mb-1">Activity:</strong>
          <p><%= activity.content %></p>
          <p><%= activity.created_at %></p>
        </div>
      <% end %>
    </div>

    <%= render @issue %>

    <%= link_to "Back to issues", issues_path, class: "ml-2 rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
    <div class="inline-block ml-2">
      <%= button_to "Destroy this issue", @issue, method: :delete, class: "mt-2 rounded-lg py-3 px-5 bg-gray-100 font-medium" %>
    </div>
  </div>
</div>
