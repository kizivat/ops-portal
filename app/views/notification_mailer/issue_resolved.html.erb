<%= ops_title "Podnet bol vyriešený" %>
<p class="ops-email-paragraph">
  <% if @issue.author == @user %>
    Dobrý deň, s radosťou Vám oznamujeme, že Váš podnet <%= ops_issue_link @issue %>, ktorý ste pridali <b><%= @issue.created_at.strftime("%d.%m.%Y") %></b> na portál Odkaz pre starostu, bol vyriešený.
  <% else %>
    Dobrý deň, s radosťou Vám oznamujeme, že podnet <%= ops_issue_link @issue %> bol vyriešený.
  <% end %>
</p>
<%= render "feedback" %>
<% if @issue.author == @user %>
  <p class="ops-email-paragraph">
    Ďakujeme za Vašu spoluprácu.
  </p>
<% end %>
<%= render "signature" %>
<%= render "unsubscribe" %>
<%= render "share" %>
<%= render "support_us" %>
<%= render "newsletter_subscribe" %>
