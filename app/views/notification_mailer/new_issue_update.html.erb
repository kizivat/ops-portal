<%= ops_title "Nová aktualizácia" %>
<p class="ops-email-paragraph">
  K podnetu <%= ops_issue_link @issue %> pribudla nová aktualizácia.
</p>
<p class="ops-email-paragraph">
  Pre detail aktualizácie, prosím, kliknite nižšie.
</p>
<p class="ops-email-paragraph">
  <%= ops_button "Detail aktualizácie", "#{issue_url(@issue)}#komentar_#{@comment.id}" %>
</p>
<p class="ops-email-paragraph">
  <%= ops_button "Reagovať na aktualizáciu", "#{issue_url(@issue)}#new_issue_activity" %>
</p>
<%= render "unsubscribe" %>
