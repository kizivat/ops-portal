<nav class="bg-white shadow">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 justify-between">
      <div class="flex">
        <div class="flex shrink-0 items-center">
          <a href="/" class="font-extrabold">Odkaz pre starostu</a>
        </div>
      </div>
      <div class="hidden sm:ml-6 sm:flex sm:items-center">
        
        <% if rodauth.logged_in? %>
          <div data-controller="dropdown" class="relative ml-3">
            <div>
              <button type="button"
                data-action="click->dropdown#toggle"
                class="relative flex rounded-full bg-white text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
                <span class="sr-only">Open user menu</span>
                <span> <%= current_user.firstname.present? && current_user.lastname.present? ? "#{current_user.firstname} #{current_user.lastname}" : current_user.email %> </span>
              </button>
            </div>

            <div data-dropdown-target="menu" class="absolute right-0 z-10 mt-2 w-48 origin-top-right rounded-md bg-white py-1 shadow-lg ring-1 ring-black/5 invisible opacity-0 scale-95 transition ease-out duration-200"
              role="menu" aria-orientation="vertical">
              <a class="block px-4 py-2 text-sm text-gray-400" role="menuitem">Your Profile</a>
              <%= button_to "Change login", rodauth.change_login_path, class: "block px-4 py-2 text-sm text-gray-700", method: :get %>
              <%= button_to "Change password", rodauth.change_password_path, class: "block px-4 py-2 text-sm text-gray-700", method: :get %>
              <%= button_to "Close account", rodauth.close_account_path, class: "block px-4 py-2 text-sm text-red-700", method: :get %>
              <%= button_to "Sign out", rodauth.logout_path, class: "block px-4 py-2 text-sm text-gray-700" %>
            </div>
          </div>
        <% else %>
          <%= button_to "Sign in", rodauth.login_path, class: "rounded-md bg-indigo-50 px-2.5 py-1.5 text-sm font-semibold text-indigo-600 shadow-sm hover:bg-indigo-100 mr-4", method: :get %>
          <%= button_to "Register", rodauth.create_account_path, class: "rounded-md bg-indigo-600 px-2.5 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600", method: :get %>
        <% end%>
      </div>
    </div>
  </div>
</nav>
