<!--Main -->
<section class="main">
  <div class="report-suggestion-block">
    <div class="report-suggestion-con">
      <div class="title">Je v tvojom okolí potrebné niečo vyriešiť?</div>
      <div class="subtitle">Odfoť, odošli a sleduj riešenie podnetu samosprávou.</div>
      <%= link_to "Nahlás podnet", new_issues_draft_path, class: "button button-report-suggestion-block" %>
    </div>
    <div class="images-block">
      <figure>
        <%= image_tag 'report-suggestion.svg' %>
      </figure>
    </div>
  </div>

  <!-- Ako na to -->
  <div class="how-to-block">
    <div class="how-to-con">
      <div class="text-wrapper">
        <div class="title">Ako to funguje?</div>
        <div class="subtitle">1. Upozornite na problém cez web alebo smartfón</div>
      </div>
      <div class="images-block">
        <figure>
          <%= image_tag 'how-to-phone.svg' %>
        </figure>
      </div>
      <div class="how-to-button-con">
        <a href="" class="button-how-to button-back inactive">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 20">
            <polygon points="2.21 19.71 .79 18.29 9.09 10 .79 1.71 2.21 .29 11.91 10 2.21 19.71"/>
          </svg>
        </a>
        <a href="" class="button-how-to button-next">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 12 20">
            <polygon points="2.21 19.71 .79 18.29 9.09 10 .79 1.71 2.21 .29 11.91 10 2.21 19.71"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

</section>

<!-- Podnety -->
<section class="home home-suggestions">

  <h1>Vyriešené podnety</h1>
  <div class="home-suggestions-con">
    <%= render @issues %>
  </div>
  <%= link_to "Pozrieť viac", issues_path, class: "button button-transparent button-read-more-home" %>
</section>

<% if @news.length > 0 %>
  <section class="home home-news">
    <h1>Aktuality</h1>
    <div class="home-news-con">
      <%= render @news %>
    </div>
    <%= link_to "Pozrieť viac", "/aktuality", class: "button button-transparent button-read-more-home" %>
  </section>
<% end %>
