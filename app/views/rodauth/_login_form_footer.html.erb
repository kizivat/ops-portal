<div class="flex items-start w-full max-w-sm">
  <% unless rodauth.login_form_footer_links.empty? %>
    <ul>
      <% rodauth.login_form_footer_links.sort.each do |_, link, text| %>
        <li><%= link_to text, link, class: "text-blue-600 rounded-sm text-sm hover:underline hover:text-blue-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600" %></li>
      <% end %>
      <li>
        <%= button_to "Login via Facebook", rodauth.omniauth_request_path(:facebook),
          method: :post, data: { turbo: false }, class: "text-blue-600 rounded-sm text-sm hover:underline hover:text-blue-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600" %>
      </li>
      <li>
        <%= button_to "Login via Google", rodauth.omniauth_request_path(:google),
          method: :post, data: { turbo: false }, class: "text-blue-600 rounded-sm text-sm hover:underline hover:text-blue-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600" %>
      </li>
    </ul>
  <% end %>
</div>