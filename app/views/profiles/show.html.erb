<% content_for(:title, @user.responsible_subject ? "Profil samosprávy" : "Môj profil") %>

<section class="profile">
  <% if @user.responsible_subject %>
    <%= render "responsible_subject_profile", user: @user %>
  <% else %>
    <%= render "citizen_profile", user: @user %>
  <% end %>
</section>
